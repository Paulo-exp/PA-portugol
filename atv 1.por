programa {
  funcao inicio() {
     real nota1, nota2, nota3, total

     escreva("digite sua primeira nota: ")
     leia(nota1)

     escreva("digite sua segunda nota: ")
     leia(nota2)

     escreva("digite sua terceira nota: ")
     leia(nota3)

     total= nota1+nota2+nota3

     escreva ("A soma é: ", total
     )
  }
}
